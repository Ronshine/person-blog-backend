<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="online.ronshine.blog.mapper.TagMapper">

    <resultMap id="BaseResultMap" type="Tag">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="slug" property="slug"/>
    </resultMap>

    <select id="findAll" resultMap="BaseResultMap">
        SELECT * FROM tags ORDER BY id
    </select>

    <select id="findAllWithCount" resultType="java.util.LinkedHashMap">
        SELECT t.id, t.name, t.slug, COUNT(pt.post_id) AS `count`
        FROM tags t
        LEFT JOIN post_tags pt ON t.id = pt.tag_id
        GROUP BY t.id, t.name, t.slug
        ORDER BY `count` DESC, t.id
    </select>

    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM tags WHERE id = #{id}
    </select>

    <select id="findBySlug" resultMap="BaseResultMap">
        SELECT * FROM tags WHERE slug = #{slug}
    </select>

    <select id="findByPostId" resultMap="BaseResultMap">
        SELECT t.* FROM tags t
        JOIN post_tags pt ON t.id = pt.tag_id
        WHERE pt.post_id = #{postId}
        ORDER BY t.id
    </select>

</mapper>
