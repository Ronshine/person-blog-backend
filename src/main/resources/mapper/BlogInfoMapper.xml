<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="online.ronshine.blog.mapper.BlogInfoMapper">

    <resultMap id="BaseResultMap" type="BlogInfo">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="subtitle" property="subtitle"/>
        <result column="description" property="description"/>
        <result column="author_name" property="authorName"/>
        <result column="author_avatar" property="authorAvatar"/>
        <result column="author_bio" property="authorBio"/>
        <result column="social_github" property="socialGithub"/>
        <result column="social_twitter" property="socialTwitter"/>
        <result column="social_email" property="socialEmail"/>
    </resultMap>

    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM blog_info WHERE id = #{id}
    </select>

    <select id="findFirst" resultMap="BaseResultMap">
        SELECT * FROM blog_info LIMIT 1
    </select>

    <update id="update" parameterType="BlogInfo">
        UPDATE blog_info
        SET title = #{title}, subtitle = #{subtitle}, description = #{description},
            author_name = #{authorName}, author_avatar = #{authorAvatar}, author_bio = #{authorBio},
            social_github = #{socialGithub}, social_twitter = #{socialTwitter}, social_email = #{socialEmail}
        WHERE id = #{id}
    </update>

</mapper>
